# Database — XAMPP MySQL on the same machine
DATABASE_URL="mysql://root:@localhost:3306/ukm_lms_new"

# Auth.js v5 — generate with:  openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Optional realtime (Pusher) — leave blank to use SSE fallback
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""

# Optional file uploads (UploadThing)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Legacy DB (only used by scripts/import-from-legacy-mysql.ts)
LEGACY_DB_URL="mysql://root:@localhost:3306/ukm_lms"

# Gemini AI (FolioBot AI in chat) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
