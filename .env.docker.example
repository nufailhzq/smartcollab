# UKMFolio (SmartCollab) — Docker runtime config
# -----------------------------------------------------------------------------
# Copy this file to `.env.docker` and fill in the real values. docker-compose
# reads it via `env_file` for the `app` service; secrets stay out of the image.

# --- MySQL service (used by both `db` and `app` services) ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=ukm_lms_new
MYSQL_USER=ukm
MYSQL_PASSWORD=ukmpass

# --- Auth.js v5 ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string
# Public URL the app is reached at. Browser must be able to GET this.
NEXTAUTH_URL=http://localhost:3000

# --- Gemini AI (FolioBot in chat) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Optional realtime (Pusher) — blank = no realtime fallback ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# --- Optional file uploads (UploadThing) ---
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
