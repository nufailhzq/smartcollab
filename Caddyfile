# Caddy reverse proxy for SmartCollab.
# Auto-provisions Let's Encrypt certificates the first time the domain
# resolves to this droplet (HTTP-01 challenge on port 80). Subsequent
# renewals happen silently every ~60 days.

smartcollab.me, www.smartcollab.me {
    encode gzip zstd

    # SSE endpoint — disable buffering and don't gzip event-streams so
    # message-bus pushes reach the browser immediately.
    @sse {
        path /api/messages/stream
    }
    reverse_proxy @sse app:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        flush_interval -1
        transport http {
            response_header_timeout 0s
            read_timeout 24h
        }
    }

    # Everything else — normal proxy with gzip.
    reverse_proxy app:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Bigger upload limit than Caddy's default for chat/folio attachments.
    request_body {
        max_size 12MB
    }
}
